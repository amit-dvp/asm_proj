{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/assembler",
            "args": ["in_out_files/a_file1" , "in_out_files/a_file2" ,  "in_out_files/a_file3"  ],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": true,
            "preLaunchTask": "Build",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
